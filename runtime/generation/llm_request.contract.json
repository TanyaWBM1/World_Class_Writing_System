{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "llm_request_contract_v1",
  "title": "LLM Draft Request",
  "type": "object",
  "required": [
    "request_id",
    "model",
    "temperature",
    "max_output_tokens",
    "instructions",
    "input"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "temperature": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 2.0
    },
    "max_output_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "object"
    }
  }
}
