{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LibraryEntry",
  "type": "object",
  "description": "Placeholder base schema for library entries.",
  "properties": {
    "entry_id": { "type": "string" },
    "library_type": { "type": "string" },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "behavior_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["entry_id", "library_type", "label"]
}
