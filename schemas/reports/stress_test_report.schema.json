{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StressTestReport",
  "type": "object",
  "description": "Placeholder schema for adversarial and break-test reports.",
  "properties": {
    "report_id": { "type": "string" },
    "target_layer": { "type": "string" },
    "case_id": { "type": "string" },
    "failure_type": { "type": "string" },
    "severity": { "type": "string" },
    "notes": { "type": "string" }
  },
  "required": ["report_id", "target_layer", "case_id"]
}
