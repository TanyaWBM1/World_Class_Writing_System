        "redundancy_score",
        "redundancy_class",
        "memory_cluster_hits",
        "distance_weighted_recurrence_score",
        "motif_candidates_detected",
        "motif_registry_matches",
        "motif_transformation_score",
        "dialogue_callback_matches",
        "dialogue_callback_legitimacy_score",
        "cluster_overuse_score",
        "role_transition_score",
        "global_redundancy_risk",
        "local_redundancy_risk",
        "recurrence_mode"
      ],
      "redundancy_classes": [
        "clean_progression",
        "legitimate_recurrence",
        "refrain_like",
        "motif_recall",
        "dialogue_callback",
        "semantic_spin",
        "collapse"
      ],
      "interpretation_rules": {
        "local_progression": "local reuse is supported by new propositions, fresh causal or contrastive relations, and healthy novelty deltas",
        "local_refrain": "repeated local phrasing is accepted when emotional or pressure-state transitions show meaningful transformation",
        "global_motif_return": "motif registry matches recur at distance with non-trivial transformation and low collapse risk",
        "dialogue_callback": "callback links connect earlier and later turns with corrective, ironic, or escalating pragmatic shift",
        "theme_reinforcement": "same thematic cluster returns with role progression, causal expansion, or state change rather than restatement alone",
        "semantic_spin": "cluster reuse is high, graph growth is weak, and transformation is marginal but not fully absent",
        "collapse": "cluster overuse is high, local and global redundancy risk converge, and role transition plus novelty deltas remain weak"
      },
      "memory_tracking": {
        "idea_cluster_fields": [
          "idea_cluster_id",
          "first_seen_segment",
          "last_seen_segment",
          "recurrence_count",
