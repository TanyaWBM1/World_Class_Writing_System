          1.0
        ],
        "decision_basis": [
          "pass if recurrence is supported by motif return, dialogue callback, role progression, or healthy theme reinforcement",
          "warn if recurrence is legitimate but overused or weakly transformed",
          "fail if overlap is high, graph growth is flat, cluster overuse is high, and role transition is weak"
        ]
      },
