  "narrative_obligation_gate": {
    "warn_above": 0.4,
    "fail_at_or_above": 0.7,
    "fail_on_any_high_importance_obligation": true
  },
  "gating_states": {
    "accepted": {
      "requires": [
        "no critical enforcement failures",
        "every dimension score >= minimum_score",
        "no validator score below fail_below",
        "no high-importance narrative obligation violated",
        "structural_violation_score below narrative obligation fail threshold",
        "reader_impact dimension >= minimum_score",
        "viral_intelligence dimension cannot override any v4 narrative failure",
        "viral_integrity_validator >= pass_min"
      ]
    },
    "accepted_with_warnings": {
      "requires": [
        "no critical enforcement failures",
        "one or more dimension scores below minimum_score but >= warning_floor",
        "no validator score below fail_below",
        "no high-importance narrative obligation violated",
        "structural_violation_score below narrative obligation fail threshold",
        "reader_impact dimension >= warning_floor",
        "viral_intelligence dimension cannot override any v4 narrative failure",
        "viral_integrity_validator >= warn_min"
      ]
    },
    "rejected": {
      "requires": [
        "any critical enforcement failure",
        "or any dimension score < warning_floor",
        "or any validator score < fail_below",
        "or structural_violation_score >= narrative obligation fail threshold",
        "or any high-importance narrative obligation is violated",
        "viral_intelligence scores never rescue a v4 structural rejection",
        "or viral_integrity_validator < fail_below",
        "or manipulation_risk >= manipulation_risk_fail",
        "or clickbait_risk >= clickbait_risk_fail"
      ]
    }
  }
